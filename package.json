{
  "name": "calificador-interactivo",
  "version": "1.0.1",
  "description": "Calificador interactivo para profesores",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Itemt/CalificadorinteractivoLNG.git"
  },
  "build": {
    "appId": "com.calificador.app",
    "productName": "Calificador Interactivo",
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "publish": ["github"]
  },
  "devDependencies": {
    "electron": "^41.5.1",
    "electron-builder": "^26.8.1"
  }
}
